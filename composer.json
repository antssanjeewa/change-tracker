{
    "name": "antssanjeewa/change-tracker",
    "description": "Custom DocBlock ChangeLog & Beautiful API Documentation Generator for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ants Sanjeewa"
        }
    ],
    "autoload": {
        "psr-4": {
            "ChangeTracker\\": "src/"
        }
    },
    "require": {
        "php": "^8.2"
    },
    "extra": {
        "laravel": {
            "providers": [
                "ChangeTracker\\ChangeTrackerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}